{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"]
  },
  "include": ["config/**/*.ts", "fixtures/**/*.ts", "pages/**/*.ts", "tests/**/*.ts", "utils/**/*.ts"]
}
